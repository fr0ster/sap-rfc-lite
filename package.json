{
  "name": "@mcp-abap-adt/sap-rfc-lite",
  "version": "0.1.1",
  "description": "Lightweight Node.js bindings for SAP NW RFC SDK",
  "license": "Apache-2.0",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "binding.gyp",
    "src",
    "lib"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "build:ts": "tsc",
    "build:cpp": "node-gyp rebuild",
    "build": "npm run build:ts && npm run build:cpp",
    "lint": "npx biome check --write src",
    "lint:check": "npx biome check src",
    "format": "npx biome format --write src",
    "test": "jest --testTimeout 60000",
    "prepare": "husky"
  },
  "config": {
    "napi_version": 8
  },
  "dependencies": {
    "node-addon-api": "^6.1.0",
    "node-gyp-build": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "gypfile": true
}
